{
  "name": "liga360-torneo-form",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "bash scripts/run_dev.sh",
    "dev:backend": "bash scripts/run_dev.sh --backend",
    "run:project": "bash ./run_project.sh",
    "run:project:win": "powershell -ExecutionPolicy Bypass -File ./run_project.ps1",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "hooks:install": "node scripts/setup-hooks.mjs",
    "migrate": "node-pg-migrate up --migrations-path database/migrations",
    "test:changed:guard": "node scripts/check-tests-required.mjs",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration": "npm run test --prefix services/inscriptions-svc && npm run test --prefix services/tournaments-svc",
    "setup:e2e": "node scripts/setup-e2e.mjs",
    "setup:e2e:clean": "node scripts/setup-e2e.mjs --clean",
    "start": "node index.js",
    "test:e2e": "playwright test --project=smoke",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:critical": "playwright test --project=critical",
    "test:e2e:all": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed:dev": "node scripts/seed-dev-data.mjs",
    "test:ci": "npm run test:unit && npm run test:integration",
    "test:ci:full": "npm run test:unit && npm run test:integration && npm run test:e2e:smoke"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "framer-motion": "^12.38.0",
    "node-pg-migrate": "^8.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-select": "^5.10.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "jsdom": "^26.1.0",
    "msw": "^2.11.2",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.4.5",
    "vite": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
