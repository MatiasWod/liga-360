{
  "name": "liga360-torneo-form",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:all": "bash scripts/run_dev.sh",
    "dev:backend": "bash scripts/run_dev.sh --backend",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "postinstall": "node -e \"try{require('child_process').execSync('git config core.hooksPath .githooks',{stdio:'pipe'})}catch(e){}\"",
    "hooks:install": "git config core.hooksPath .githooks",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration": "npm run test --prefix services/inscriptions-svc && npm run test --prefix services/tournaments-svc",
    "setup:e2e": "npx playwright install chromium",
    "start": "node index.js",
    "test:e2e": "playwright test --project=critical",
    "test:e2e:critical": "playwright test --project=critical",
    "test:e2e:all": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed:dev": "node scripts/seed-dev-data.mjs",
    "seed:fix-auth": "node scripts/fix-auth-demo-users.mjs",
    "migrate:auth:local": "npm run migrate:auth:local --prefix database",
    "elo:backfill": "node scripts/elo-backfill.mjs",
    "seed:stats-demo": "node scripts/seed-stats-demo.mjs",
    "seed:world-cup-2022": "node scripts/seed-world-cup-2022.mjs",
    "seed:next-edition-demo": "node scripts/seed-next-edition-demo.mjs",
    "try:next-edition": "node scripts/try-next-edition.mjs",
    "seed:all": "npm run seed:dev && npm run seed:stats-demo && npm run seed:world-cup-2022",
    "dev:bootstrap": "bash scripts/dev-bootstrap.sh",
    "test:ci": "npm run test:unit && npm run test:integration",
    "test:ci:full": "npm run test:unit && npm run test:integration && npm run test:e2e:smoke"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "framer-motion": "^12.38.0",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.11",
    "prom-client": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-select": "^5.10.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "baseline-browser-mapping": "^2.10.36",
    "jsdom": "^26.1.0",
    "msw": "^2.11.2",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.4.5",
    "vite": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
