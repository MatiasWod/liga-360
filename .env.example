# Liga360 — variables para docker compose y referencia para Kubernetes.
# Copiar a .env en la raíz: cp .env.example .env
# No commitear .env: contiene secretos reales.

# --- PostgreSQL ---
POSTGRES_USER=liga
POSTGRES_PASSWORD=liga
POSTGRES_DB=liga360

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- Auth / microservicios ---
# Secreto compartido para firmar y validar los JWT (todos los servicios lo usan).
# Generar uno propio, p. ej.: openssl rand -hex 64
JWT_SECRET=devsecret

# --- Admin bootstrap (auth-svc) ---
# El admin se crea al arrancar auth-svc (no hay registro de admins). Cambiar en cualquier
# entorno que no sea dev local.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@liga360.com.ar
ADMIN_PASSWORD=admin123

# --- Mail / verificación de email (auth-svc) ---
# Envío de los mails de verificación de cuenta. Si SMTP_HOST queda vacío, auth-svc no envía
# el mail (el registro igual funciona; el fallo solo se loguea).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# Base para construir el link de verificación que se manda por mail.
FRONTEND_URL=http://localhost:5173


# DOCKER_USER=your-dockerhub-user
# DOCKER_PASSWORD=your-dockerhub-token

# --- Kubernetes (ver deploy/k8s/README.md) ---
# Imágenes locales: tag liga360/<service>:local tras docker compose build
# Secretos: copiar deploy/k8s/secrets.env.example → deploy/k8s/secrets.env y aplicar con kubectl
