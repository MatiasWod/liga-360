# Liga360 — variables para docker compose y referencia para Kubernetes.
# Copiar a .env en la raíz: cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=liga
POSTGRES_PASSWORD=liga
POSTGRES_DB=liga360

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- Auth / microservicios ---
JWT_SECRET=devsecret

# --- Frontend (Vite dev; en Docker/K8s el proxy usa rutas /api/* por defecto) ---
# VITE_TOURNAMENTS_GRAPHQL_URL=/api/graphql
# VITE_TEAMS_API_URL=/api/teams
# VITE_AUTH_API_URL=/api/auth
# VITE_INSCRIPTIONS_API_URL=/api/inscriptions

# --- Scripts / E2E (opcional) ---
# SEED_PASSWORD=SeedLiga360!
# AUTH_URL=http://localhost:4003
# TEAMS_URL=http://localhost:4002
# INSCRIPTIONS_URL=http://localhost:4004
# GRAPHQL_URL=http://localhost:4000/graphql
# E2E_PORT=4174
# PLAYWRIGHT_REUSE_SERVER=1

# --- CI / registry (Bitbucket Pipelines) ---
# DOCKER_USER=your-dockerhub-user
# DOCKER_PASSWORD=your-dockerhub-token

# --- Kubernetes (ver k8s/README.md) ---
# Imágenes locales: tag liga360/<service>:local tras docker compose build
# Secretos: copiar k8s/secrets.env.example → k8s/secrets.env y aplicar con kubectl
